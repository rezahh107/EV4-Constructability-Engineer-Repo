{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ev4.local/schemas/ce/ce-stage-payload.v1.schema.json",
  "title": "EV4 CE Stage Payload v1",
  "x-ev4-schema-id": "ev4-ce-stage-payload@1.0.0",
  "x-ev4-schema-version": "1.0.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version",
    "owner_repository",
    "payload_status",
    "payload_identity",
    "source_architect_intake",
    "architecture_identity",
    "constructability_review",
    "implementation_strategy_map",
    "builder_executable_package",
    "builder_package_emitted",
    "builder_package_not_emitted_reason",
    "evidence_register",
    "unresolved_evidence",
    "repair_routing",
    "boundary_assertions",
    "validation_contract",
    "extension_records"
  ],
  "properties": {
    "schema_id": {"const": "ev4-ce-stage-payload@1.0.0"},
    "schema_version": {"const": "1.0.0"},
    "owner_repository": {"const": "rezahh107/EV4-Constructability-Engineer-Repo"},
    "payload_status": {"enum": ["complete", "insufficient_evidence"]},
    "payload_identity": {"$ref": "#/$defs/payload_identity"},
    "source_architect_intake": {"$ref": "#/$defs/source_architect_intake"},
    "architecture_identity": {"$ref": "#/$defs/architecture_identity"},
    "constructability_review": {"type": "object", "additionalProperties": true},
    "implementation_strategy_map": {"type": ["object", "null"], "additionalProperties": true},
    "builder_executable_package": {"type": ["object", "null"], "additionalProperties": true},
    "builder_package_emitted": {"type": "boolean"},
    "builder_package_not_emitted_reason": {"type": ["string", "null"]},
    "evidence_register": {"type": "array", "items": {"$ref": "#/$defs/evidence"}},
    "unresolved_evidence": {"type": "array", "items": {"type": "object", "additionalProperties": true}},
    "repair_routing": {"type": "object", "additionalProperties": true},
    "boundary_assertions": {"$ref": "#/$defs/boundary_assertions"},
    "validation_contract": {"type": "object", "additionalProperties": true},
    "extension_records": {"type": "array", "items": {"type": "object", "additionalProperties": true}}
  },
  "allOf": [
    {
      "if": {"properties": {"builder_package_emitted": {"const": false}}, "required": ["builder_package_emitted"]},
      "then": {"properties": {"builder_executable_package": {"type": "null"}}, "required": ["builder_package_not_emitted_reason"]}
    },
    {
      "if": {"properties": {"builder_package_emitted": {"const": true}}, "required": ["builder_package_emitted"]},
      "then": {"properties": {"builder_package_not_emitted_reason": {"type": "null"}, "builder_executable_package": {"type": "object"}}}
    },
    {
      "if": {"properties": {"payload_status": {"const": "insufficient_evidence"}}, "required": ["payload_status"]},
      "then": {"properties": {"unresolved_evidence": {"minItems": 1}}}
    }
  ],
  "$defs": {
    "payload_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["payload_id", "pipeline_id", "run_id", "synthetic"],
      "properties": {
        "payload_id": {"type": "string", "minLength": 1},
        "pipeline_id": {"const": "ev4-ce-project-gate-producer-pipeline"},
        "run_id": {"type": "string", "minLength": 1},
        "synthetic": {"type": "boolean"}
      }
    },
    "source_architect_intake": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_id", "schema_version", "artifact_ref", "artifact_hash", "transition_metadata_is_review_evidence"],
      "properties": {
        "schema_id": {"const": "ev4-ce-architect-stage-intake@1.1.0"},
        "schema_version": {"const": "1.1.0"},
        "artifact_ref": {"type": "string", "minLength": 1},
        "artifact_hash": {"$ref": "#/$defs/hash"},
        "transition_metadata_is_review_evidence": {"const": false}
      }
    },
    "architecture_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "selected_candidate_id",
        "selected_candidate_locked",
        "selected_candidate_id_unchanged",
        "approved_class_names",
        "approved_class_names_unchanged",
        "build_tree_identity_preserved",
        "review_unit_traces"
      ],
      "properties": {
        "selected_candidate_id": {"type": "string", "minLength": 1},
        "selected_candidate_locked": {"const": true},
        "selected_candidate_id_unchanged": {"const": true},
        "approved_class_names": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "approved_class_names_unchanged": {"const": true},
        "build_tree_identity_preserved": {"const": true},
        "architect_unknowns_preserved": {"type": "boolean"},
        "architect_forbidden_work_weakened": {"const": false},
        "review_unit_traces": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/review_unit_trace"}}
      }
    },
    "review_unit_trace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["architect_node_ref", "architect_evidence_refs", "ce_review_unit_id", "identity_unchanged"],
      "properties": {
        "architect_node_ref": {"type": "string", "minLength": 1},
        "architect_evidence_refs": {"type": "array", "items": {"type": "string"}},
        "ce_review_unit_id": {"type": "string", "minLength": 1},
        "identity_unchanged": {"const": true}
      }
    },
    "boundary_assertions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ce_did_not_redesign_architecture", "ce_did_not_claim_builder_execution", "ce_did_not_claim_responsive_completion", "production_ready"],
      "properties": {
        "ce_did_not_redesign_architecture": {"const": true},
        "ce_did_not_claim_builder_execution": {"const": true},
        "ce_did_not_claim_responsive_completion": {"const": true},
        "production_ready": {"const": false}
      }
    },
    "hash": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "value", "scope"],
      "properties": {
        "algorithm": {"const": "sha256"},
        "value": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "scope": {"enum": ["canonical_json", "file_bytes", "external_artifact"]}
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "state", "description", "source"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "kind": {"type": "string", "minLength": 1},
        "state": {"enum": ["observed", "validated", "derived", "synthetic", "insufficient_evidence"]},
        "description": {"type": "string", "minLength": 1},
        "source": {"type": "object", "additionalProperties": true}
      }
    }
  }
}
