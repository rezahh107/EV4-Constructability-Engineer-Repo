{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EV4 Builder Executable Package",
  "type": "object",
  "required": [
    "schema",
    "package_id",
    "review_ref",
    "architect_contract",
    "selected_candidate_id",
    "approved_class_names",
    "builder_package_status",
    "builder_decisions_required",
    "blocking_dependencies",
    "selected_candidate_locked",
    "selected_candidate_id_unchanged",
    "approved_class_names_unchanged",
    "confirmation_request",
    "first_safe_builder_batch"
  ],
  "additionalProperties": true,
  "allOf": [
    {
      "if": {
        "required": ["visual_parity_build"],
        "properties": {"visual_parity_build": {"const": true}}
      },
      "then": {
        "required": ["reference_paradigm_lock", "paradigm_to_structure_map"]
      }
    }
  ],
  "properties": {
    "schema": {"type": "string", "const": "ev4-builder-executable-package@1.0.0"},
    "package_id": {"type": "string"},
    "review_ref": {"type": "string"},
    "strategy_map_ref": {"type": ["string", "null"]},
    "architect_contract": {"$ref": "#/$defs/architect_contract"},
    "selected_candidate_id": {"type": "string"},
    "approved_class_names": {"type": "array", "items": {"type": "string"}},
    "builder_package_status": {"type": "string", "const": "executable_ready"},
    "builder_decisions_required": {"type": "integer", "const": 0},
    "blocking_dependencies": {"type": "array", "maxItems": 0},
    "selected_candidate_locked": {"type": "boolean", "const": true},
    "selected_candidate_id_unchanged": {"type": "boolean", "const": true},
    "approved_class_names_unchanged": {"type": "boolean", "const": true},
    "confirmation_request": {"$ref": "#/$defs/confirmation_request"},
    "first_safe_builder_batch": {"$ref": "#/$defs/builder_batch"},
    "visual_parity_build": {"type": "boolean"},
    "reference_paradigm_lock": {"$ref": "#/$defs/reference_paradigm_lock"},
    "paradigm_to_structure_map": {"$ref": "#/$defs/paradigm_to_structure_map"},
    "known_unknowns": {"type": "object", "additionalProperties": true},
    "logged_assumptions": {"type": "array", "items": {"type": "object"}},
    "qa_status": {"type": "object", "additionalProperties": true}
  },
  "$defs": {
    "architect_contract": {
      "type": "object",
      "required": ["source_ref", "selected_candidate_id", "approved_class_names"],
      "additionalProperties": true,
      "properties": {
        "source_ref": {"type": "string", "minLength": 1},
        "selected_candidate_id": {"type": "string", "minLength": 1},
        "approved_class_names": {
          "type": "array",
          "items": {"type": "string"},
          "uniqueItems": true
        }
      }
    },
    "confirmation_request": {
      "type": "object",
      "required": ["confirmation_id", "confirmed_action_ids", "expected_user_token"],
      "additionalProperties": true,
      "properties": {
        "confirmation_id": {"type": "string"},
        "confirmed_action_ids": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "expected_user_token": {"type": "string"}
      }
    },
    "builder_batch": {
      "type": "object",
      "required": ["batch_id", "actions"],
      "additionalProperties": true,
      "properties": {
        "batch_id": {"type": "string"},
        "risk": {"type": "string", "enum": ["low", "medium", "high"]},
        "actions": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/builder_action"}}
      }
    },
    "builder_action": {
      "type": "object",
      "required": ["action_id", "action_type", "target_node", "parameters", "requires_decision"],
      "additionalProperties": true,
      "properties": {
        "action_id": {"type": "string"},
        "action_type": {"type": "string"},
        "target_node": {"type": "string"},
        "parameters": {"type": "object"},
        "requires_decision": {"type": "boolean", "const": false}
      }
    },
    "reference_paradigm_lock": {
      "type": "object",
      "required": [
        "schema",
        "source_reference_id",
        "extracted_by",
        "paradigm_locked",
        "layout_paradigm",
        "primary_anchor",
        "distribution_model",
        "repeated_unit_form",
        "connector_model",
        "spatial_symmetry",
        "completion_signature"
      ],
      "additionalProperties": false,
      "properties": {
        "schema": {"const": "ev4-reference-paradigm-lock@1.0.0"},
        "source_reference_id": {"type": "string", "minLength": 1},
        "extracted_by": {"const": "constructability_engineer"},
        "paradigm_locked": {"const": true},
        "layout_paradigm": {
          "enum": [
            "center-anchored-symmetric",
            "vertical-list",
            "grid",
            "split-hero",
            "radial-diagram",
            "unknown"
          ]
        },
        "primary_anchor": {"type": "string", "minLength": 1},
        "distribution_model": {"type": "string", "minLength": 1},
        "repeated_unit_form": {"type": "string", "minLength": 1},
        "connector_model": {"type": "string", "minLength": 1},
        "spatial_symmetry": {"type": "string", "minLength": 1},
        "completion_signature": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "paradigm_to_structure_map": {
      "type": "object",
      "required": [
        "primary_anchor",
        "regions",
        "repeated_units",
        "connector_layer",
        "first_batch_requirements"
      ],
      "additionalProperties": false,
      "properties": {
        "primary_anchor": {
          "type": "object",
          "required": ["node", "role"],
          "additionalProperties": true,
          "properties": {
            "node": {"type": "string", "minLength": 1},
            "role": {"type": "string", "minLength": 1}
          }
        },
        "regions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "distribution", "expected_count", "nodes"],
            "additionalProperties": true,
            "properties": {
              "id": {"type": "string", "minLength": 1},
              "distribution": {"type": "string", "minLength": 1},
              "expected_count": {"type": "integer", "minimum": 1},
              "nodes": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
            }
          }
        },
        "repeated_units": {
          "type": "object",
          "required": ["form", "required_children"],
          "additionalProperties": true,
          "properties": {
            "form": {"type": "string", "minLength": 1},
            "required_children": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
          }
        },
        "connector_layer": {
          "type": "object",
          "required": ["node", "model"],
          "additionalProperties": true,
          "properties": {
            "node": {"type": "string", "minLength": 1},
            "model": {"type": "string", "minLength": 1}
          }
        },
        "first_batch_requirements": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
