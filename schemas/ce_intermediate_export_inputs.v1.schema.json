{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ev4.local/schemas/ce/ce-intermediate-export-inputs.v1.schema.json",
  "title": "EV4 CE Independent Intermediate Export Inputs v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version",
    "run_id",
    "constructability_review",
    "implementation_strategy_map",
    "builder_executable_package"
  ],
  "properties": {
    "schema_id": {"const": "ev4-ce-intermediate-export-inputs@1.0.0"},
    "schema_version": {"const": "1.0.0"},
    "run_id": {"type": "string", "minLength": 1},
    "constructability_review": {"type": "object"},
    "implementation_strategy_map": {"type": ["object", "null"]},
    "builder_executable_package": {"type": ["object", "null"]}
  }
}
