{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/rezahh107/EV4-Constructability-Engineer-Repo/schemas/architect_ce_input_package.v1.schema.json",
  "title": "EV4 Architect to CE Input Package v1",
  "description": "Strict CE ingestion contract for normalized Architect output. It accepts only non-executable Architect data prepared for constructability review and rejects Builder-ready claims before CE proof.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "contract_version",
    "source_architect_schema",
    "ingestion_target",
    "accepted_for_ce_review",
    "builder_executable_allowed",
    "builder_ready_status",
    "selected_candidate_id",
    "selected_candidate_locked",
    "production_ready_allowed",
    "architect_contract",
    "source_payload_ledger",
    "approved_structure_tree",
    "approved_class_names",
    "ce_review_units",
    "evidence_gaps_for_ce",
    "forbidden_work",
    "mapping_trace",
    "identity_consistency_checks",
    "pre_ingestion_validation",
    "ce_ingestion_policy"
  ],
  "properties": {
    "schema": { "const": "ev4-architect-to-ce-input-package@1.0.0" },
    "contract_version": { "const": "1.0.0" },
    "source_architect_schema": { "const": "ev4-architect-output-contract@1.0.0" },
    "ingestion_target": { "const": "constructability_review" },
    "accepted_for_ce_review": { "const": true },
    "builder_executable_allowed": { "const": false },
    "builder_ready_status": { "const": "not_builder_ready_without_ce_proof" },
    "selected_candidate_id": { "$ref": "#/$defs/id_string" },
    "selected_candidate_locked": { "const": true },
    "production_ready_allowed": { "const": false },
    "architect_contract": { "$ref": "#/$defs/architect_contract" },
    "source_payload_ledger": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/source_payload_ref" }
    },
    "approved_structure_tree": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/approved_structure_node" }
    },
    "approved_class_names": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/class_name" }
    },
    "ce_review_units": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/ce_review_unit" }
    },
    "evidence_gaps_for_ce": {
      "type": "array",
      "items": { "$ref": "#/$defs/evidence_gap" }
    },
    "forbidden_work": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/non_empty_string" }
    },
    "mapping_trace": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/mapping_trace_entry" }
    },
    "identity_consistency_checks": { "$ref": "#/$defs/identity_consistency_checks" },
    "pre_ingestion_validation": { "$ref": "#/$defs/pre_ingestion_validation" },
    "ce_ingestion_policy": { "$ref": "#/$defs/ce_ingestion_policy" }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1,
      "pattern": ".*\\S.*"
    },
    "id_string": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "class_name": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z][A-Za-z0-9_-]*$"
    },
    "source_payload_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["payload_name", "source_stage", "source_status"],
      "properties": {
        "payload_name": { "$ref": "#/$defs/non_empty_string" },
        "source_stage": {
          "enum": [
            "/intake",
            "/research",
            "/decompose",
            "/architectures",
            "/score-evidence",
            "/score-audit",
            "/recommend",
            "/build-tree",
            "/implementation",
            "/final-audit",
            "/handoff-export",
            "/builder-feed-export"
          ]
        },
        "source_status": {
          "enum": ["observed", "validated", "proposed", "unverified", "insufficient_evidence"]
        }
      }
    },
    "architect_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_ref",
        "source_stage",
        "selected_candidate_id",
        "approved_class_names",
        "forbidden_work"
      ],
      "properties": {
        "source_ref": { "$ref": "#/$defs/non_empty_string" },
        "source_stage": { "const": "/builder-feed-export" },
        "selected_candidate_id": { "$ref": "#/$defs/id_string" },
        "approved_class_names": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/class_name" }
        },
        "forbidden_work": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/non_empty_string" }
        }
      }
    },
    "approved_structure_node": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "node_id",
        "parent_node_id",
        "node_type",
        "approved_role",
        "approved_class_names",
        "child_node_ids",
        "architecture_locked"
      ],
      "properties": {
        "node_id": { "$ref": "#/$defs/id_string" },
        "parent_node_id": {
          "anyOf": [
            { "$ref": "#/$defs/id_string" },
            { "type": "null" }
          ]
        },
        "node_type": {
          "enum": [
            "section",
            "container",
            "grid",
            "column",
            "widget",
            "decoration",
            "connector_layer",
            "unknown_structural_node"
          ]
        },
        "approved_role": { "$ref": "#/$defs/non_empty_string" },
        "approved_class_names": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/class_name" }
        },
        "child_node_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/id_string" }
        },
        "architecture_locked": { "const": true }
      }
    },
    "ce_review_unit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "unit_id",
        "source_node_id",
        "action_proposed",
        "node_type",
        "approved_class_names",
        "interrogation_inputs",
        "default_ce_status",
        "builder_action_authorized"
      ],
      "properties": {
        "unit_id": { "$ref": "#/$defs/id_string" },
        "source_node_id": { "$ref": "#/$defs/id_string" },
        "action_proposed": { "$ref": "#/$defs/non_empty_string" },
        "node_type": {
          "enum": [
            "section",
            "container",
            "grid",
            "column",
            "widget",
            "decoration",
            "connector_layer",
            "unknown_structural_node"
          ]
        },
        "approved_class_names": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/class_name" }
        },
        "interrogation_inputs": { "$ref": "#/$defs/interrogation_inputs" },
        "default_ce_status": { "const": "blocked" },
        "builder_action_authorized": { "const": false }
      }
    },
    "interrogation_inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "geometry",
        "source_target_anchors",
        "asset",
        "placeholder_policy",
        "overlay",
        "containment",
        "z_index",
        "responsive",
        "interaction",
        "dynamic_loop",
        "accessibility",
        "elementor_ui_control_path",
        "reversibility",
        "class_boundary",
        "structure_boundary"
      ],
      "properties": {
        "geometry": { "$ref": "#/$defs/proof_state" },
        "source_target_anchors": { "$ref": "#/$defs/proof_state" },
        "asset": { "$ref": "#/$defs/proof_state" },
        "placeholder_policy": { "$ref": "#/$defs/proof_state" },
        "overlay": { "$ref": "#/$defs/proof_state" },
        "containment": { "$ref": "#/$defs/proof_state" },
        "z_index": { "$ref": "#/$defs/proof_state" },
        "responsive": { "$ref": "#/$defs/proof_state" },
        "interaction": { "$ref": "#/$defs/proof_state" },
        "dynamic_loop": { "$ref": "#/$defs/proof_state" },
        "accessibility": { "$ref": "#/$defs/proof_state" },
        "elementor_ui_control_path": { "$ref": "#/$defs/proof_state" },
        "reversibility": { "$ref": "#/$defs/proof_state" },
        "class_boundary": { "$ref": "#/$defs/boundary_state" },
        "structure_boundary": { "$ref": "#/$defs/boundary_state" }
      }
    },
    "proof_state": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "state", "evidence_refs"],
      "properties": {
        "required": { "type": "boolean" },
        "state": { "enum": ["not_required", "evidence_backed", "not_proven", "blocked"] },
        "evidence_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        }
      },
      "allOf": [
        {
          "if": { "properties": { "required": { "const": false } }, "required": ["required"] },
          "then": {
            "properties": {
              "state": { "const": "not_required" },
              "evidence_refs": { "maxItems": 0 }
            }
          }
        },
        {
          "if": { "properties": { "state": { "const": "evidence_backed" } }, "required": ["state"] },
          "then": { "properties": { "evidence_refs": { "minItems": 1 } } }
        }
      ]
    },
    "boundary_state": {
      "type": "object",
      "additionalProperties": false,
      "required": ["crosses_boundary", "state", "evidence_refs"],
      "properties": {
        "crosses_boundary": { "type": "boolean" },
        "state": { "enum": ["preserved", "not_proven", "requires_architect_amendment", "blocked"] },
        "evidence_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        }
      },
      "allOf": [
        {
          "if": { "properties": { "crosses_boundary": { "const": true } }, "required": ["crosses_boundary"] },
          "then": { "properties": { "state": { "enum": ["requires_architect_amendment", "blocked"] } } }
        }
      ]
    },
    "evidence_gap": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gap_id", "affected_unit_ids", "gap_type", "required_before_builder"],
      "properties": {
        "gap_id": { "$ref": "#/$defs/id_string" },
        "affected_unit_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/id_string" }
        },
        "gap_type": {
          "enum": [
            "geometry_not_proven",
            "anchor_not_proven",
            "asset_source_missing",
            "placeholder_policy_missing",
            "overlay_strategy_not_proven",
            "responsive_behavior_not_proven",
            "interaction_not_approved",
            "dynamic_loop_not_approved",
            "accessibility_evidence_missing",
            "ui_control_path_missing",
            "architect_amendment_required"
          ]
        },
        "required_before_builder": { "const": true }
      }
    },
    "mapping_trace_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from_architect_path", "to_ce_path", "mapping_rule", "loss_policy"],
      "properties": {
        "from_architect_path": { "$ref": "#/$defs/non_empty_string" },
        "to_ce_path": { "$ref": "#/$defs/non_empty_string" },
        "mapping_rule": {
          "enum": [
            "copy_exact",
            "flatten_unique_class_names",
            "normalize_node_to_review_unit",
            "convert_gap_to_not_proven_state",
            "preserve_forbidden_work",
            "preserve_source_payload_ledger",
            "reject_if_builder_ready_claim",
            "reject_if_unmapped_freeform"
          ]
        },
        "loss_policy": { "const": "no_loss_allowed" }
      }
    },
    "identity_consistency_checks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "selected_candidate_id_matches_architect_contract",
        "approved_class_names_match_architect_contract",
        "all_review_units_target_existing_nodes",
        "all_evidence_gaps_target_existing_units",
        "forbidden_work_preserved_from_architect_output"
      ],
      "properties": {
        "selected_candidate_id_matches_architect_contract": { "const": true },
        "approved_class_names_match_architect_contract": { "const": true },
        "all_review_units_target_existing_nodes": { "const": true },
        "all_evidence_gaps_target_existing_units": { "const": true },
        "forbidden_work_preserved_from_architect_output": { "const": true }
      }
    },
    "pre_ingestion_validation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "verified_by",
        "architect_schema_valid",
        "no_additional_properties",
        "no_builder_ready_claim",
        "selected_candidate_locked",
        "approved_class_names_resolved",
        "all_review_units_mapped",
        "source_payload_ledger_preserved",
        "forbidden_work_preserved",
        "evidence_gaps_preserved",
        "identity_consistency_verified",
        "unmapped_fields"
      ],
      "properties": {
        "verified_by": { "enum": ["project_gate_validator", "ce_adapter_validator", "manual_contract_review"] },
        "architect_schema_valid": { "const": true },
        "no_additional_properties": { "const": true },
        "no_builder_ready_claim": { "const": true },
        "selected_candidate_locked": { "const": true },
        "approved_class_names_resolved": { "const": true },
        "all_review_units_mapped": { "const": true },
        "source_payload_ledger_preserved": { "const": true },
        "forbidden_work_preserved": { "const": true },
        "evidence_gaps_preserved": { "const": true },
        "identity_consistency_verified": { "const": true },
        "unmapped_fields": { "type": "array", "maxItems": 0 }
      }
    },
    "ce_ingestion_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "semantic_guessing_allowed",
        "builder_package_emission_allowed_at_ingestion",
        "default_status_when_proof_missing",
        "ambiguous_fields_allowed"
      ],
      "properties": {
        "semantic_guessing_allowed": { "const": false },
        "builder_package_emission_allowed_at_ingestion": { "const": false },
        "default_status_when_proof_missing": { "const": "blocked" },
        "ambiguous_fields_allowed": { "const": false }
      }
    }
  }
}
