{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EV4 Constructability Review Report",
  "type": "object",
  "required": ["review_id", "architect_package_ref", "selected_candidate_id", "constructability_status", "builder_decisions_required", "blocking_dependencies", "reviewed_nodes"],
  "additionalProperties": true,
  "properties": {
    "review_id": {"type": "string"},
    "architect_package_ref": {"type": "string"},
    "selected_candidate_id": {"type": "string"},
    "constructability_status": {"type": "string", "enum": ["executable_ready", "blocked", "needs_user_evidence", "needs_architect_amendment", "executable_with_logged_assumption"]},
    "builder_decisions_required": {"type": "integer", "minimum": 0},
    "blocking_dependencies": {"type": "array", "items": {"type": "string"}},
    "engineer_questions": {"type": "array", "items": {"type": "string"}},
    "logged_assumptions": {"type": "array", "items": {"$ref": "#/$defs/assumption"}},
    "reviewed_nodes": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/node_review"}},
    "qa_status": {"type": "object", "additionalProperties": true}
  },
  "$defs": {
    "assumption": {
      "type": "object",
      "required": ["assumption_id", "description", "risk_level", "reversible", "visible_in_output"],
      "additionalProperties": true,
      "properties": {
        "assumption_id": {"type": "string"},
        "description": {"type": "string"},
        "risk_level": {"type": "string", "enum": ["low", "medium", "high"]},
        "reversible": {"type": "boolean"},
        "visible_in_output": {"type": "boolean"},
        "crosses_architecture_boundary": {"type": "boolean"}
      }
    },
    "node_review": {
      "type": "object",
      "required": ["node_id", "node_type", "action_proposed", "node_status", "interrogation_result"],
      "additionalProperties": true,
      "properties": {
        "node_id": {"type": "string"},
        "node_type": {"type": "string"},
        "action_proposed": {"type": "string"},
        "node_status": {"type": "string", "enum": ["executable_ready", "blocked", "needs_user_evidence", "needs_architect_amendment", "executable_with_logged_assumption"]},
        "blocking_reason": {"type": ["string", "null"]},
        "interrogation_result": {"$ref": "#/$defs/interrogation_result"}
      }
    },
    "interrogation_result": {
      "type": "object",
      "required": ["geometry_required", "asset_required", "overlay_strategy_required", "responsive_behavior", "interaction_implied", "dynamic_loop_implied", "accessibility_claimed", "exact_ui_control_path_used", "requires_class_change", "requires_structure_change"],
      "additionalProperties": true,
      "properties": {
        "geometry_required": {"type": "boolean"},
        "geometry_proven": {"type": ["boolean", "null"]},
        "asset_required": {"type": "boolean"},
        "asset_source_present": {"type": ["boolean", "null"]},
        "placeholder_policy_present": {"type": ["boolean", "null"]},
        "overlay_strategy_required": {"type": "boolean"},
        "overlay_strategy_proven": {"type": ["boolean", "null"]},
        "responsive_behavior": {"type": "string", "enum": ["not_applicable", "blocked", "evidence_backed", "unknown"]},
        "action_targets_responsive": {"type": "boolean"},
        "interaction_implied": {"type": "boolean"},
        "interaction_approved": {"type": ["boolean", "null"]},
        "dynamic_loop_implied": {"type": "boolean"},
        "dynamic_loop_approved": {"type": ["boolean", "null"]},
        "accessibility_claimed": {"type": "boolean"},
        "accessibility_evidenced": {"type": ["boolean", "null"]},
        "exact_ui_control_path_used": {"type": "boolean"},
        "ui_control_evidence_present": {"type": ["boolean", "null"]},
        "reversible_if_wrong": {"type": "boolean"},
        "requires_class_change": {"type": "boolean"},
        "requires_structure_change": {"type": "boolean"},
        "architect_decomposition_permission": {"type": "boolean"}
      }
    }
  }
}
