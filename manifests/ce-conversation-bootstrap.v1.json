{"$schema":"../schemas/ce-conversation-bootstrap.v1.schema.json","contract_id":"ev4-ce-conversation-bootstrap","contract_version":"1.0.0","owner_repository":"rezahh107/EV4-Constructability-Engineer-Repo","activation_mode":"integrated_authorized_ce_startup","routing_request_contract":{"required_fields":["message","operating_mode","active_ce_run","attachments"],"operating_modes":["auto","user_facing_new_ce_run","active_ce_run","repository_maintenance"],"integrated_decision_function":"route_request"},"trigger_policy":{"policy_id":"ce-bootstrap-trigger-policy-v1","canonical_trigger":"شروع","trigger_type":"exact_message_after_normalization","normalization_policy":{"policy_id":"ce-bootstrap-normalization-policy-v1","unicode_normalization":"NFC","trim_surrounding_whitespace":true,"case_folding":false,"aliases":[]},"bare_message_only":true,"trigger_with_attachments":"attachment_first_intake","attachment_without_authorized_context":"forbidden","active_ce_run_allows_later_attachment":true,"repository_maintenance_precedence":"always"},"bootstrap_response":"EV4 Constructability Engineer آماده است.\n\nبرای شروع بررسی Constructability، فایل `ce-input.json` و source bundle دقیق آن را که توسط مسیر `EV4-Project-Gate / architect-to-ce` استفاده شده است ارسال کن.\n\nورودی باید با قرارداد `ev4-ce-architect-stage-intake@1.1.0` معتبر باشد و binding آن با bytes واقعی source bundle تأیید شود.\nفایل `project-gate-a2c-receipt.json` تا اعتبارسنجی رسمی فقط evidence تشخیصیِ غیرقابل‌اعتماد است و جایگزین ورودی CE نیست.\n\nپس از اعتبارسنجی ورودی و source binding، بررسی فقط از مرحله `architect_intake_validation` آغاز می‌شود.\nتا پیش از آن، هیچ نتیجه Constructability، استراتژی اجرا یا آمادگی Builder اعلام نمی‌شود.","canonical_input":{"schema_id":"ev4-ce-architect-stage-intake@1.1.0","filename_hint":"ce-input.json","filename_is_authority":false,"source_transition":"ev4-architect-to-ce-transition@1.0.0","official_schema_path":"schemas/ce_architect_stage_intake.v1_1.schema.json","official_validator_path