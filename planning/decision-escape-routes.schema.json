{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ev4.local/schemas/decision-escape-routes.schema.json",
  "title": "EV4 Decision Escape Routes State",
  "description": "Schema for planning/DECISION_ESCAPE_ROUTES.yml. It validates recorded escape-route enforcement evidence without proving remote CI completion.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "consumer_repo",
    "consumer_repo_evidence_state",
    "last_updated",
    "brc_reference",
    "kernel_reference",
    "records"
  ],
  "properties": {
    "schema_version": {
      "const": 3
    },
    "consumer_repo": {
      "const": "EV4-Constructability-Engineer-Repo"
    },
    "consumer_repo_evidence_state": {
      "const": "expected_unverified"
    },
    "last_updated": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "date",
        "pr",
        "commit"
      ],
      "properties": {
        "date": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
        },
        "pr": {
          "type": [
            "string",
            "null"
          ]
        },
        "commit": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "brc_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "document",
        "profile"
      ],
      "properties": {
        "document": {
          "const": "Behavioral_Rule_Coverage_v0.4.1"
        },
        "profile": {
          "const": "EV4_CONSUMER_DECISION_TRIGGER_ARCHITECTURE_v0.4.1"
        }
      }
    },
    "kernel_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repo",
        "decision_taxonomy_version",
        "decision_cards_version"
      ],
      "properties": {
        "repo": {
          "const": "EV4-Decision-Kernel"
        },
        "decision_taxonomy_version": {
          "type": [
            "string",
            "null"
          ]
        },
        "decision_cards_version": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "escape_route_id",
          "consumer_repo",
          "risk",
          "session_scope",
          "mapping_status",
          "decision_family",
          "required_decision_card_ref_pattern",
          "not_applicable_reason",
          "surface",
          "status",
          "carriers",
          "notes"
        ],
        "properties": {
          "escape_route_id": {
            "type": "string",
            "pattern": "^[A-Z0-9_-]+$"
          },
          "consumer_repo": {
            "const": "EV4-Constructability-Engineer-Repo"
          },
          "risk": {
            "enum": [
              "Critical",
              "High",
              "Medium",
              "Low"
            ]
          },
          "session_scope": {
            "enum": [
              "single_turn",
              "cross_turn"
            ]
          },
          "mapping_status": {
            "enum": [
              "mapped",
              "unmapped",
              "insufficient_evidence",
              "not_applicable_with_reason"
            ]
          },
          "surface": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "enforcement_status",
              "evidence_state"
            ],
            "properties": {
              "enforcement_status": {
                "enum": [
                  "prose_only",
                  "schema_backed",
                  "validator_backed",
                  "fixture_tested",
                  "ci_enforced",
                  "sequence_ci_enforced",
                  "downstream_contract_enforced",
                  "insufficient_evidence"
                ]
              },
              "evidence_state": {
                "enum": [
                  "observed",
                  "validated",
                  "resolved",
                  "derived",
                  "proposed",
                  "unverified",
                  "insufficient_evidence"
                ]
              }
            }
          },
          "carriers": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "sequence_CI_step",
              "test_command",
              "positive_fixture",
              "negative_fixture",
              "validator_rule",
              "validator_diagnostic",
              "downstream_contract"
            ],
            "properties": {
              "sequence_CI_step": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "test_command": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "positive_fixture": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "negative_fixture": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "validator_rule": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "validator_diagnostic": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "downstream_contract": {
                "type": [
                  "string",
                  "null"
                ]
              }
            }
          },
          "notes": {
            "type": "string",
            "minLength": 1
          },
          "decision_family": {
            "type": [
              "string",
              "null"
            ]
          },
          "required_decision_card_ref_pattern": {
            "type": [
              "string",
              "null"
            ]
          },
          "not_applicable_reason": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "not": {
          "anyOf": [
            {
              "required": [
                "resolved"
              ]
            },
            {
              "required": [
                "production_ready"
              ]
            }
          ]
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "mapping_status": {
                  "const": "mapped"
                }
              },
              "required": [
                "mapping_status"
              ]
            },
            "then": {
              "properties": {
                "decision_family": {
                  "type": "string",
                  "minLength": 1
                },
                "required_decision_card_ref_pattern": {
                  "type": "string",
                  "minLength": 1
                },
                "not_applicable_reason": {
                  "type": "null"
                }
              },
              "required": [
                "decision_family",
                "required_decision_card_ref_pattern",
                "not_applicable_reason"
              ]
            }
          },
          {
            "if": {
              "properties": {
                "mapping_status": {
                  "const": "not_applicable_with_reason"
                }
              },
              "required": [
                "mapping_status"
              ]
            },
            "then": {
              "properties": {
                "decision_family": {
                  "type": "null"
                },
                "required_decision_card_ref_pattern": {
                  "type": "null"
                },
                "not_applicable_reason": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "required": [
                "decision_family",
                "required_decision_card_ref_pattern",
                "not_applicable_reason"
              ]
            }
          },
          {
            "if": {
              "properties": {
                "status": {
                  "properties": {
                    "enforcement_status": {
                      "const": "sequence_ci_enforced"
                    }
                  },
                  "required": [
                    "enforcement_status"
                  ]
                }
              },
              "required": [
                "status"
              ]
            },
            "then": {
              "properties": {
                "carriers": {
                  "properties": {
                    "sequence_CI_step": {
                      "type": "string",
                      "minLength": 1
                    },
                    "test_command": {
                      "type": "string",
                      "minLength": 1
                    },
                    "positive_fixture": {
                      "type": "string",
                      "minLength": 1
                    },
                    "negative_fixture": {
                      "type": "string",
                      "minLength": 1
                    },
                    "validator_rule": {
                      "type": "string",
                      "minLength": 1
                    },
                    "validator_diagnostic": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "required": [
                    "sequence_CI_step",
                    "test_command",
                    "positive_fixture",
                    "negative_fixture",
                    "validator_rule",
                    "validator_diagnostic"
                  ]
                }
              }
            }
          }
        ]
      }
    }
  },
  "not": {
    "required": [
      "routes"
    ]
  }
}
